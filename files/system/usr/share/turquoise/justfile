# Add user to all required groups and set zsh as default shell
system:
    #!/usr/bin/env bash
    set -euo pipefail
    ME="$(whoami)"

    add_group() {
        local grp="$1"
        getent group "$grp" &>/dev/null || { echo "  skipping $grp (group not found)"; return; }
        groups "$ME" | grep -qw "$grp" && return
        sudo usermod -aG "$grp" "$ME"
        echo "  added to $grp"
    }

    echo "Configuring group memberships..."
    for grp in wheel libvirt kvm lp optical storage video input i2c systemd-journal; do
        add_group "$grp"
    done

    ZSH_PATH="$(command -v zsh)"
    [[ "$SHELL" == "$ZSH_PATH" ]] || sudo usermod -s "$ZSH_PATH" "$ME"

# Replace default zRAM with a 16GB swap file on /var (optional; not in setup)
swap:
    #!/usr/bin/env bash
    set -euo pipefail
    if swapon --show | grep -q '/var/swapfile'; then
        echo "Swap file already active, nothing to do."
        exit 0
    fi
    sudo touch /etc/systemd/zram-generator.conf
    sudo swapoff /dev/zram0 2>/dev/null || true
    # fallocate doesn't work on btrfs; use btrfs-native mkswapfile instead
    sudo rm -f /var/swapfile
    sudo btrfs filesystem mkswapfile --size 16G /var/swapfile
    sudo swapon /var/swapfile
    grep -q '/var/swapfile' /etc/fstab || echo '/var/swapfile none swap defaults 0 0' | sudo tee -a /etc/fstab
    swapon --show

# Configure SSH agent socket and load personal key (requires ~/.ssh/id_ed25519; not in setup)
ssh-setup:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ ! -f "$HOME/.ssh/id_ed25519" ]]; then
        echo "No ~/.ssh/id_ed25519 found — this recipe is for Samuel's personal setup only."
        exit 1
    fi
    systemctl --user enable --now ssh-agent.socket
    export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
    SSH_ASKPASS_REQUIRE=never ssh-add ~/.ssh/id_ed25519
    # Append auto-load snippet to ~/.zshrc if not already present
    if ! grep -q 'ssh-add.*id_ed25519' "$HOME/.zshrc" 2>/dev/null; then
        printf '\n# Auto-load SSH key on first terminal (added by sjust ssh-setup)\n[[ -S "$SSH_AUTH_SOCK" ]] && { ssh-add -l &>/dev/null || SSH_ASKPASS_REQUIRE=never ssh-add ~/.ssh/id_ed25519; }\n' >> "$HOME/.zshrc"
        echo "Added ssh-add auto-load to ~/.zshrc."
    fi
    echo "SSH agent socket enabled and key loaded."

# Set up Obsidian CLI wrapper — enables CLI toggle and verifies wrapper is deployed (not in setup)
obsidian-cli:
    #!/usr/bin/env bash
    set -euo pipefail
    OBSIDIAN_JSON="$HOME/.var/app/md.obsidian.Obsidian/config/obsidian/obsidian.json"

    flatpak info md.obsidian.Obsidian &>/dev/null || {
        echo "Obsidian Flatpak not installed. Run 'sjust flatpaks' first."
        exit 1
    }

    pgrep -f "md.obsidian.Obsidian" &>/dev/null && {
        echo "Obsidian is running — close it first so the config change isn't overwritten."
        exit 1
    }

    [[ -f "$OBSIDIAN_JSON" ]] || {
        echo "obsidian.json not found at $OBSIDIAN_JSON — launch Obsidian at least once first."
        exit 1
    }

    python3 -c "import json; fp='$OBSIDIAN_JSON'; data=json.load(open(fp)); data['cli']=True; json.dump(data, open(fp,'w')); print('CLI toggle enabled in obsidian.json')"

    [[ -x "$HOME/.local/bin/obsidian" ]] \
        && echo "Wrapper at ~/.local/bin/obsidian is in place." \
        || echo "Warning: ~/.local/bin/obsidian not found — run 'sjust chezmoi' to deploy dotfiles first."

    echo "Done. Launch Obsidian to activate the socket, then test with: obsidian files"

# Configure Obsidian vault name and path (updates chezmoi data)
obsidian-vault name path:
    #!/usr/bin/env bash
    set -euo pipefail
    ABS_PATH=$(realpath -m "{{path}}")
    DATA_FILE="{{HOME}}/dotfiles/.chezmoidata.yaml"
    mkdir -p "$(dirname "$DATA_FILE")"
    printf "obsidian:\n  vault_name: \"{{name}}\"\n  vault_path: \"$ABS_PATH\"\n" > "$DATA_FILE"
    echo "Updated Obsidian vault configuration in $DATA_FILE"
    echo "Vault Name: {{name}}"
    echo "Vault Path: $ABS_PATH"
    echo "Applying changes..."
    chezmoi apply --force

# Download mechvibes soundpacks and install patched nk-cream config (not in setup)
wayvibes-soundpacks:
    #!/usr/bin/env bash
    set -euo pipefail
    DEST="$HOME/wayvibes/soundpacks"
    WORK=$(mktemp -d)
    trap "rm -rf '$WORK'" EXIT

    command -v wayvibes &>/dev/null || { echo "wayvibes not found — is the image up to date?"; exit 1; }

    echo "Cloning mechvibes audio packs..."
    git clone --depth=1 --filter=blob:none --sparse https://github.com/hainguyents13/mechvibes.git "$WORK/mechvibes"
    git -C "$WORK/mechvibes" sparse-checkout set src/audio

    mkdir -p "$DEST"
    cp -r "$WORK/mechvibes/src/audio/." "$DEST/"

    # Replace nk-cream config.json with our patched version.
    # The patch adds keycodes 125 and 139, which are what keyd emits for
    # capslock and the ThinkPad start button (both remapped keys).
    cp {{SHARE}}/wayvibes/nk-cream-config.json "$DEST/nk-cream/config.json"

    echo "Done — soundpacks installed to $DEST"

# Set up arch-box (Stremio + RustDesk) distrobox with app exports
distroboxes:
    #!/usr/bin/env bash
    set -euo pipefail
    trap 'echo ""; echo "FAILED at line $LINENO: $BASH_COMMAND"; exit 1' ERR

    echo "=== arch-box (Stremio + RustDesk) ==="
    distrobox rm --force --yes arch-box 2>/dev/null || true
    rm -f "$HOME/.local/share/applications/"*stremio* 2>/dev/null || true
    rm -f "$HOME/.local/share/applications/"*rustdesk* 2>/dev/null || true
    rm -f "$HOME/.local/bin/"*stremio* 2>/dev/null || true
    rm -f "$HOME/.local/bin/"*rustdesk* 2>/dev/null || true
    rm -rf "$HOME/.config/stremio-enhanced" 2>/dev/null || true

    distrobox create --name arch-box --image archlinux:latest --yes
    distrobox enter --name arch-box -- bash -c '
      set -euo pipefail
      sudo pacman -Syu --noconfirm
      sudo pacman -S --noconfirm base-devel git
      cd /tmp && rm -rf yay-bin
      git clone https://aur.archlinux.org/yay-bin.git && cd yay-bin && makepkg -si --noconfirm
    '
    distrobox enter --name arch-box -- bash -c '
      set -euo pipefail
      yay -S --noconfirm stremio-enhanced-bin rustdesk-bin ffmpeg gst-plugins-good gst-plugins-bad gst-plugins-ugly gst-libav
    '
    distrobox enter --name arch-box -- bash -c '
      set -euo pipefail
      mkdir -p "$HOME/.config/stremio-enhanced/streamingserver"
      wget -O "$HOME/.config/stremio-enhanced/streamingserver/server.js" \
        "https://dl.strem.io/server/v4.20.18/desktop/server.js"
    '
    distrobox enter --name arch-box -- distrobox-export --app stremio-enhanced
    distrobox enter --name arch-box -- distrobox-export --app rustdesk
    mkdir -p "$HOME/.config/systemd/user"
    printf '%s\n' \
      '[Unit]' \
      'Description=RustDesk remote desktop (arch-box)' \
      'After=network.target' \
      '' \
      '[Service]' \
      'ExecStart=distrobox enter --name arch-box -- rustdesk --service' \
      'Restart=on-failure' \
      '' \
      '[Install]' \
      'WantedBy=default.target' \
      > "$HOME/.config/systemd/user/rustdesk.service"
    systemctl --user daemon-reload
    systemctl --user enable --now rustdesk
    echo "arch-box done."

# System maintenance: health check, image upgrade, flatpaks, brew, distroboxes, firmware (not in setup)
update:
    #!/usr/bin/env bash
    set -euo pipefail
    echo -e "\033[33mNOTE: uupd handles image, flatpaks, homebrew, and distroboxes automatically daily at 4am.\033[0m"
    echo -e "\033[33mNOTE: Some packages built from source in image recipe are PINNED and won't update without manual intervention; others pull latest release without notification.\033[0m"

    echo -e "\n\033[34m=== System Health Check ===\033[0m"
    echo -e "\033[36m  \$ systemctl --failed\033[0m"
    systemctl --failed || true

    echo -e "\n\033[34m=== Empty Trash? ===\033[0m"
    if command -v trash-empty >/dev/null; then
        trash-empty
    else
        gio trash --empty || true
    fi

    echo -e "\n\033[34m=== Staging Image Update (bootc upgrade) ===\033[0m"
    echo -e "\033[36m  \$ sudo bootc upgrade\033[0m"
    sudo bootc upgrade

    echo -e "\n\033[34m=== Updating Flatpaks ===\033[0m"
    echo -e "\033[36m  \$ flatpak update -y\033[0m"
    flatpak update -y || true

    echo -e "\n\033[34m=== Removing Unused Flatpak Runtimes ===\033[0m"
    echo -e "\033[36m  \$ flatpak uninstall --unused -y\033[0m"
    flatpak uninstall --unused -y || true

    echo -e "\n\033[34m=== Updating Distroboxes ===\033[0m"
    if command -v distrobox >/dev/null; then
        echo -e "\033[36m  \$ distrobox upgrade --all\033[0m"
        distrobox upgrade --all || true
    else
        echo -e "\033[31m  Distrobox not found, skipping.\033[0m"
    fi

    echo -e "\n\033[34m=== Updating Homebrew and Packages ===\033[0m"
    if command -v brew >/dev/null; then
        sudo chown -R "$(whoami):wheel" /home/linuxbrew 2>/dev/null || true
        sudo chmod -R g+rwX /home/linuxbrew 2>/dev/null || true
        echo -e "\033[36m  \$ brew update && brew upgrade && brew cleanup\033[0m"
        brew update && brew upgrade && brew cleanup
    else
        echo -e "\033[31m  Homebrew not found, skipping.\033[0m"
    fi

    echo -e "\n\033[34m=== Updating pipx Packages ===\033[0m"
    if command -v pipx >/dev/null; then
        sjust pipx
    else
        echo -e "\033[31m  pipx not found, skipping.\033[0m"
    fi

    echo -e "\n\033[34m=== Checking Firmware Updates ===\033[0m"
    fwupdmgr refresh && fwupdmgr get-updates || true

    echo -e "\n\033[32mUpdate sequence complete!\033[0m"

# Fix Btrfs transparent compression on composefs (Fedora 42+ / Bluefin 44+)
fix-compression:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Applying Btrfs zstd compression workaround..."

    # 1. Update kernel args if not already present
    if rpm-ostree kargs | grep -q "compress=zstd"; then
        echo "  Kernel arguments already updated."
    else
        echo "  Adding compress=zstd:1 to kernel arguments..."
        cur=$(rpm-ostree kargs | grep -o 'rootflags=[^ ]*' || true)
        if [ -n "$cur" ]; then
            sudo rpm-ostree kargs --delete="$cur" --append="${cur},compress=zstd:1"
        else
            sudo rpm-ostree kargs --append=rootflags=subvol=root,compress=zstd:1
        fi
    fi

    # 2. Comment out root mount in /etc/fstab if not already commented
    if grep -E '^[^\#].*\s+/\s+btrfs' /etc/fstab >/dev/null; then
        echo "  Commenting out root mount in /etc/fstab..."
        sudo sed -i.bak 's/^\([^#].*\s\+\/\s\+btrfs\)/# \1/' /etc/fstab
        echo "  /etc/fstab updated (backup saved as /etc/fstab.bak)."
    else
        echo "  Root mount in /etc/fstab is already commented out."
    fi

    echo "Workaround applied. Please reboot your system to activate compression."

# ── HP ZBook Ultra G1a (Strix Halo) — turquoise-halo only ────────────────────
# Everything the turquoise-halo image can't/shouldn't bake: per-machine post-
# install (compression, groups, amd-debug-tools), verification of baked features,
# and the NPU kernel-arg toggle. Hardware notes:
#   ~/Dropbox/.../Custom Image/HP ZBook Ultra G1a 14'' Ryzen AI Max+ 395.md
#   ~/Dropbox/.../Local LLMs/Strix Halo LLM Guide.md
# Guarded by /usr/share/turquoise/image-id so they no-op on the P14s.

# Strix Halo post-install: compression, groups, suspend tools, then verify (turquoise-halo only)
halo:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ "$(cat /usr/share/turquoise/image-id 2>/dev/null)" != "turquoise-halo" ]]; then
        echo -e "\033[31mThis recipe is for the turquoise-halo image (HP ZBook Ultra G1a) only.\033[0m"
        echo "  Current image-id: $(cat /usr/share/turquoise/image-id 2>/dev/null || echo unknown)"
        exit 1
    fi

    echo -e "\033[34m=== 1/4 Groups + shell (sjust system) ===\033[0m"
    sjust system

    echo -e "\n\033[34m=== 2/4 Btrfs compression workaround (sjust fix-compression) ===\033[0m"
    sjust fix-compression

    echo -e "\n\033[34m=== 3/4 Suspend debug tools (amd-debug-tools → amd-s2idle) ===\033[0m"
    # Not packaged for Fedora — superm1's upstream pipx tool. Provides `amd-s2idle`.
    if command -v pipx >/dev/null && pipx list --short 2>/dev/null | grep -q '^amd-debug-tools'; then
        echo "  amd-debug-tools already installed."
    elif command -v pipx >/dev/null; then
        echo "  Installing amd-debug-tools via pipx..."
        pipx install amd-debug-tools || echo -e "  \033[33mInstall failed — run 'sjust pipx' / check network.\033[0m"
    else
        echo -e "  \033[33mpipx not found — run 'sjust pipx' first.\033[0m"
    fi

    echo -e "\n\033[34m=== 4/4 Verifying baked hardware enablement ===\033[0m"
    sjust halo-verify || true

    echo -e "\n\033[41;97m  MANUAL STEPS — NOT done by this script. You must do these yourself.  \033[0m"
    echo -e "\033[33m  (firmware/install-time settings; no software, including sjust, can apply them)\033[0m"
    echo ""
    echo -e "\033[36m  ▶ BIOS/UEFI — enter setup at boot and set each of these by hand:\033[0m"
    echo "      [ ] Secure Boot ............................ DISABLED  (required for the vanilla kernel)"
    echo "      [ ] Pluton ................................. ENABLED   (s2idle suspend breaks if disabled)"
    echo "      [ ] Integrated Graphics UMA Frame Buffer ... 512 MB    (not Auto/large)"
    echo "      [ ] Fan offset ............................. +2        (steady low spin instead of cycling)"
    echo "      [ ] ASPM ................................... default   (do not force off)"
    echo -e "\033[36m  ▶ Install-time (only relevant on a fresh install — already chosen at Anaconda):\033[0m"
    echo "      [ ] Btrfs + LUKS full-disk encryption"
    echo -e "\033[33m  None of the above are verified by 'sjust halo-verify' — they are firmware-only.\033[0m"
    echo ""
    echo -e "\033[36m  ▶ Now: REBOOT\033[0m to activate the compression workaround + any karg changes."
    echo -e "\033[36m  ▶ After reboot: run 'sjust halo-llm'\033[0m to set up the NPU distrobox + lemond service."
    echo -e "\n\033[32mhalo setup complete (automated steps).\033[0m Manual BIOS steps above are still up to you."

# Verify turquoise-halo baked features: kargs, webcam, sched-ext, NPU, suspend (read-only)
halo-verify:
    #!/usr/bin/env bash
    set -uo pipefail
    pass() { echo -e "  \033[32m✓\033[0m $*"; }
    warn() { echo -e "  \033[33m!\033[0m $*"; }
    fail() { echo -e "  \033[31m✗\033[0m $*"; }

    if [[ "$(cat /usr/share/turquoise/image-id 2>/dev/null)" != "turquoise-halo" ]]; then
        warn "image-id is not turquoise-halo — these checks assume the Halo image."
    fi

    echo -e "\033[34mKernel arguments (baked via kargs module)\033[0m"
    KARGS="$(rpm-ostree kargs 2>/dev/null || true)"
    for arg in amd_pstate=active ttm.pages_limit=32505856; do
        grep -q -- "$arg" <<<"$KARGS" && pass "$arg" || fail "$arg MISSING"
    done
    if grep -q -- 'amd_iommu=off' <<<"$KARGS"; then
        warn "amd_iommu=off present → XDNA2 NPU DISABLED (iGPU max-speed mode). 'sjust halo-npu on' to re-enable."
    else
        pass "amd_iommu=off absent → NPU enabled (autocomplete/embeddings available)"
    fi
    grep -q 'compress=zstd' <<<"$KARGS" && pass "compress=zstd in kargs" \
        || warn "compress=zstd not in kargs — run 'sjust fix-compression' + reboot"

    echo -e "\033[34mBtrfs compression (journal)\033[0m"
    if journalctl -k -g 'use zstd compression' 2>/dev/null | grep -q zstd; then
        pass "btrfs zstd compression active"
    else
        warn "no 'use zstd compression' in kernel log (reboot after fix-compression, or check perms)"
    fi

    echo -e "\033[34mWebcam — AMD ISP4 kmod (built at image time)\033[0m"
    lsmod | grep -q amd_isp4_capture && pass "amd_isp4_capture loaded" || warn "amd_isp4_capture not loaded"
    if command -v v4l2-ctl >/dev/null; then
        v4l2-ctl --list-devices 2>/dev/null | grep -qi isp && pass "ISP4 video device present" \
            || warn "no ISP4 device in v4l2-ctl --list-devices"
    fi

    echo -e "\033[34msched-ext schedulers\033[0m"
    systemctl is-enabled scx_loader.service &>/dev/null && pass "scx_loader.service enabled" || fail "scx_loader.service not enabled"
    SCX="$(scxctl get 2>/dev/null || sudo -n scxctl get 2>/dev/null || true)"
    [[ -n "$SCX" ]] && pass "active scheduler: $SCX" || warn "scxctl get returned nothing (try: sudo scxctl get)"

    echo -e "\033[34mAC-wakeup suspend fix\033[0m"
    systemctl is-enabled ac-wakeup-disable.service &>/dev/null && pass "ac-wakeup-disable.service enabled" || fail "ac-wakeup-disable.service not enabled"

    echo -e "\033[34miGPU memory (GTT)\033[0m"
    if journalctl -k -g 'GTT memory' 2>/dev/null | grep -qi 'GTT memory'; then
        pass "$(journalctl -k -g 'GTT memory' 2>/dev/null | tail -1 | sed 's/.*]: *//')"
    else
        warn "no 'GTT memory' line in kernel log (check perms or reboot)"
    fi

    echo -e "\033[34mNPU (XDNA2 / amdxdna)\033[0m"
    if [[ -e /dev/accel/accel0 ]]; then
        pass "/dev/accel/accel0 present"
    else
        warn "/dev/accel/accel0 absent — NPU off (amd_iommu=off set?) or kernel/firmware too old"
    fi
    MLOCK_CONF=/etc/systemd/system/user@.service.d/memlock.conf
    [[ -f "$MLOCK_CONF" ]] \
        && pass "LimitMEMLOCK=infinity configured ($MLOCK_CONF)" \
        || warn "memlock limit not raised — run 'sjust halo-llm'"
    distrobox list 2>/dev/null | grep -q 'npu-lemonade' \
        && pass "npu-lemonade distrobox exists" \
        || warn "npu-lemonade distrobox missing — run 'sjust halo-llm'"
    if systemctl --user is-active --quiet npu-lemond.service 2>/dev/null; then
        pass "npu-lemond.service active (lemond :13305, NPU-enabled)"
    elif systemctl --user is-active --quiet lemond.service 2>/dev/null; then
        warn "lemond.service active (host RPM, no NPU) — run 'sjust halo-llm' to switch to NPU build"
    else
        warn "no lemond service running — run 'sjust halo-llm'"
    fi

    echo -e "\033[34mSuspend test tooling\033[0m"
    command -v amd-s2idle >/dev/null && pass "amd-s2idle available — run 'sudo amd-s2idle test' to validate s2idle" \
        || warn "amd-s2idle not installed — run 'sjust halo' or 'pipx install amd-debug-tools'"

# Toggle the XDNA2 NPU on/off via the amd_iommu kernel arg, then reboot (turquoise-halo only)
halo-npu mode:
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{mode}}" in
      on)
        if rpm-ostree kargs | grep -q -- 'amd_iommu=off'; then
            sudo rpm-ostree kargs --delete='amd_iommu=off'
            echo -e "\033[32mNPU enabled\033[0m (amd_iommu=off removed). Reboot to apply."
        else
            echo "NPU already enabled (amd_iommu=off not set)."
        fi
        ;;
      off)
        if rpm-ostree kargs | grep -q -- 'amd_iommu=off'; then
            echo "NPU already disabled (amd_iommu=off set)."
        else
            sudo rpm-ostree kargs --append='amd_iommu=off'
            echo -e "\033[32miGPU max-speed mode\033[0m (amd_iommu=off added, ~5–12% LLM boost; NPU disabled). Reboot to apply."
        fi
        ;;
      *)
        echo "usage: sjust halo-npu on|off"
        echo "  on  = NPU enabled (autocomplete/embeddings) — default"
        echo "  off = max iGPU LLM speed, NPU disabled"
        exit 1
        ;;
    esac

# Set up the local LLM stack: NPU distrobox (XRT + FLM + lemond), memlock fix, user service (turquoise-halo only)
# Run after 'sjust halo' + reboot. Idempotent — safe to re-run.
# See: ~/Dropbox/.../Local LLMs/Strix Halo LLM Guide.md §2.C
halo-llm:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ "$(cat /usr/share/turquoise/image-id 2>/dev/null)" != "turquoise-halo" ]]; then
        echo -e "\033[31mThis recipe is for the turquoise-halo image only.\033[0m"; exit 1
    fi
    pass() { echo -e "  \033[32m✓\033[0m $*"; }
    info() { echo -e "  \033[34m→\033[0m $*"; }
    fail() { echo -e "  \033[31m✗\033[0m $*"; }

    # 1. Memlock — NPU inference requires locking model weights in RAM (default 8 MB is too low)
    echo -e "\n\033[34m=== 1/4 Memlock limit (LimitMEMLOCK=infinity) ===\033[0m"
    MLOCK_CONF=/etc/systemd/system/user@.service.d/memlock.conf
    if [[ -f "$MLOCK_CONF" ]]; then
        pass "Already configured."
    else
        sudo mkdir -p "$(dirname "$MLOCK_CONF")"
        printf '[Service]\nLimitMEMLOCK=infinity\n' | sudo tee "$MLOCK_CONF" >/dev/null
        sudo systemctl daemon-reload
        pass "Configured. You must reboot (or log out/in) before NPU inference will work in this session."
    fi

    # 2. npu-lemonade distrobox — Ubuntu 24.04 with /dev/accel/accel0 for the XDNA2 NPU.
    # FLM (FastFlowLM) only ships Ubuntu/Debian debs; this box provides the XRT + FLM runtime
    # that the host Fedora image can't install directly.
    echo -e "\n\033[34m=== 2/4 npu-lemonade distrobox (Ubuntu 24.04 + NPU device) ===\033[0m"
    if distrobox list 2>/dev/null | grep -q 'npu-lemonade'; then
        pass "Already exists."
    else
        info "Creating distrobox with /dev/accel/accel0 passthrough..."
        distrobox create --name npu-lemonade \
            --image docker.io/library/ubuntu:24.04 \
            --additional-flags "--device /dev/accel/accel0" \
            --yes
        pass "Created."
    fi

    # 3. XRT + FastFlowLM + lemonade-server inside the distrobox
    echo -e "\n\033[34m=== 3/4 XRT + FastFlowLM + lemonade-server inside distrobox ===\033[0m"
    if distrobox enter npu-lemonade -- bash -c "command -v flm && command -v lemond" &>/dev/null; then
        pass "Already installed."
    else
        info "Fetching latest FLM release..."
        FLM_URL=$(curl -sf https://api.github.com/repos/FastFlowLM/FastFlowLM/releases/latest \
            | python3 -c "import json,sys; a=[x for x in json.load(sys.stdin)['assets'] if 'ubuntu24.04' in x['name']]; print(a[0]['browser_download_url'])")
        info "Installing inside distrobox (apt + deb download — a few minutes)..."
        distrobox enter npu-lemonade -- bash -c "
            set -euo pipefail
            sudo apt-get update -qq
            sudo apt-get install -y software-properties-common wget -qq
            sudo add-apt-repository -y ppa:lemonade-team/stable 2>&1 | tail -1
            sudo apt-get update -qq
            sudo apt-get install -y libxrt-npu2 lemonade-server -qq
            wget -q '$FLM_URL' -O /tmp/flm.deb
            sudo apt-get install -y /tmp/flm.deb -qq
        "
        pass "Installed."
    fi
    info "Validating NPU stack..."
    distrobox enter npu-lemonade -- flm validate

    # 4. npu-lemond user service — runs the distrobox lemond on :13305.
    # The Ubuntu lemond binary (with XRT + FLM support) replaces the host RPM lemond.
    # Distrobox uses host networking, so :13305 is accessible from the host unchanged.
    echo -e "\n\033[34m=== 4/4 npu-lemond user service ===\033[0m"
    # Disable host lemond to avoid port 13305 conflict
    systemctl --user stop  lemond.service 2>/dev/null || true
    systemctl --user disable lemond.service 2>/dev/null || true

    mkdir -p ~/.config/systemd/user/
    cat > ~/.config/systemd/user/npu-lemond.service << 'EOF'
[Unit]
Description=Lemonade Server (NPU, via npu-lemonade distrobox)
After=network-online.target

[Service]
Type=simple
ExecStart=distrobox enter npu-lemonade -- lemond
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target
EOF
    systemctl --user daemon-reload
    systemctl --user enable --now npu-lemond.service
    sleep 3
    if systemctl --user is-active --quiet npu-lemond.service; then
        pass "npu-lemond.service running on :13305"
    else
        fail "Service failed to start — check: journalctl --user -u npu-lemond.service -n 30"
    fi

    echo ""
    echo -e "\033[32mLocal LLM stack ready.\033[0m"
    echo "  NPU models (autocomplete + embeddings) — pull with lemonade:"
    echo "    lemonade pull Qwen2.5-Coder-1.5B-Instruct-NPU   # VS Code autocomplete"
    echo "    lemonade pull nomic-embed-text-v2-moe-GGUF       # RAG embeddings"
    echo "  iGPU models (big reasoning) — ramalama aliases from ~/.zshrc:"
    echo "    serve-brain    goose-brain    goose-dense"
    echo ""
    echo "  NOTE: if this was the first memlock configuration, reboot before pulling NPU models."
