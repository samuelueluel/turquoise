set shell := ["bash", "-euo", "pipefail", "-c"]

HOME      := env_var("HOME")
SHARE     := "/usr/share/turquoise"
ZSH_PLUGS := HOME + "/.local/share/zsh/plugins"
ZEN_DIR   := HOME + "/.config/zen"

# List available recipes
default:
    @just --justfile /usr/share/turquoise/justfile --list --unsorted

# Full setup — run everything in order
setup: dirs zen chezmoi zen-extensions brew pipx flatpaks system
    update-desktop-database ~/.local/share/applications/ 2>/dev/null || true
    gtk-update-icon-cache -f -t /usr/share/icons/oreo_spark_orange_cursors 2>/dev/null || true
    gtk-update-icon-cache -f -t /usr/share/icons/Papirus 2>/dev/null || true
    @echo ""
    @echo "Done. Manual steps remaining:"
    @echo "  - Log out and back in for group changes to take effect"
    @echo "  - Dropbox: sign in"
    @echo "  - EasyEffects: open app to confirm presets loaded"

# Pre-create required directories
dirs:
    mkdir -p \
        {{HOME}}/.local/bin \
        {{HOME}}/.local/share/applications \
        {{HOME}}/.local/share/zsh/plugins \
        {{HOME}}/.config \
        {{HOME}}/.gnome2/accels \
        {{HOME}}/.ssh \
        {{HOME}}/.npm-global/bin
    chmod 700 {{HOME}}/.ssh

# Register Zen profiles, create .desktop launchers, set zen-utility as default browser (optional; before chezmoi)
zen:
    #!/usr/bin/env bash
    set -euo pipefail
    command -v zen-browser &>/dev/null || { echo "Zen Browser not found, skipping."; exit 0; }

    # Create profile directories
    mkdir -p "{{ZEN_DIR}}/zen.personal" "{{ZEN_DIR}}/zen.utility" "{{ZEN_DIR}}/zen.work"

    # Write profiles.ini and installs.ini — the Install block and installs.ini
    # ensure that Zen doesn't create a new hashed profile on rebase/update.
    # The hash 544180EF0598BAEE is specific to the /usr/bin/zen-browser path.
    printf '%s\n' '[General]' 'StartWithLastProfile=1' 'Version=2' '' \
        '[Profile0]' 'Name=personal' 'IsRelative=1' 'Path=zen.personal' 'Default=1' '' \
        '[Profile1]' 'Name=utility' 'IsRelative=1' 'Path=zen.utility' '' \
        '[Profile2]' 'Name=work' 'IsRelative=1' 'Path=zen.work' '' \
        '[Install544180EF0598BAEE]' 'Default=zen.personal' \
        > "{{ZEN_DIR}}/profiles.ini"

    printf '%s\n' '[544180EF0598BAEE]' 'Default=zen.personal' > "{{ZEN_DIR}}/installs.ini"

    declare -A ICONS=( ["personal"]="/usr/share/icons/Papirus/48x48/apps/a7xpg.svg" ["utility"]="/usr/share/icons/Papirus/48x48/apps/braindump.svg" ["work"]="/usr/share/icons/Papirus/48x48/apps/applications-office.svg" )
    declare -A NAMES=( ["personal"]="Personal" ["utility"]="Utility" ["work"]="Work" )
    for profile in personal utility work; do
        CAP="${NAMES[$profile]}"
        NAME="Zen ($CAP)"
        ICON="${ICONS[$profile]}"
        FILE="{{HOME}}/.local/share/applications/zen-${profile}.desktop"
        cat > "$FILE" <<EOF
    [Desktop Entry]
    Name=$NAME
    Comment=Launch Zen Browser with the $CAP profile
    Exec=env MOZ_APP_REMOTINGNAME=zen-$profile zen-browser -P "$profile" %u
    Icon=$ICON
    Terminal=false
    Type=Application
    Categories=Network;WebBrowser;
    StartupWMClass=zen-$profile
    MimeType=x-scheme-handler/unknown;x-scheme-handler/about;x-scheme-handler/https;x-scheme-handler/http;text/html;
    EOF
        chmod +x "$FILE"
    done

    xdg-settings set default-web-browser zen-utility.desktop 2>/dev/null || true
    for mime in x-scheme-handler/http x-scheme-handler/https text/html \
                application/xhtml+xml application/x-extension-html \
                application/x-extension-shtml application/x-extension-xhtml \
                x-scheme-handler/about x-scheme-handler/unknown; do
        xdg-mime default zen-utility.desktop "$mime" 2>/dev/null || true
    done

# Deploy dotfiles from image snapshot, init chezmoi, apply (before brew)
chezmoi:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ ! -d "$HOME/dotfiles/.git" ]]; then
        echo "Populating ~/dotfiles from image snapshot..."
        rsync -a {{SHARE}}/dotfiles/ "$HOME/dotfiles/"
    fi
    chezmoi init --source="$HOME/dotfiles"
    chezmoi apply --force
    systemctl --user enable empty-trash.service || true
    gsettings set org.gnome.desktop.interface icon-theme Papirus
    gsettings set org.gnome.desktop.interface cursor-theme oreo_spark_orange_cursors
    systemctl --user restart xdg-desktop-portal-gtk.service 2>/dev/null || true
    systemctl --user restart xdg-desktop-portal.service 2>/dev/null || true

# Install Zen Browser extensions into each profile (optional; after chezmoi)
zen-extensions:
    #!/usr/bin/env bash
    set -euo pipefail
    command -v zen-browser &>/dev/null || { echo "Zen Browser not found, skipping."; exit 0; }

    PERSONAL="{{ZEN_DIR}}/zen.personal"
    UTILITY="{{ZEN_DIR}}/zen.utility"
    WORK="{{ZEN_DIR}}/zen.work"
    CUSTOM="{{HOME}}/dotfiles/zen-extensions"

    amo() {
        local dir="$1" slug="$2" id="$3"
        mkdir -p "$dir/extensions"
        echo "  [amo] $slug"
        curl -sL "https://addons.mozilla.org/firefox/downloads/latest/$slug/" -o "$dir/extensions/$id"
    }

    custom() {
        local dir="$1" src="$2" id="$3"
        mkdir -p "$dir/extensions"
        echo "  [custom] $src"
        cp "{{HOME}}/dotfiles/zen-extensions/$src" "$dir/extensions/$id"
    }

    echo "Installing Zen extensions..."

    for PROFILE in "$PERSONAL" "$UTILITY" "$WORK"; do
        [[ -d "$PROFILE" ]] || continue
        amo    "$PROFILE" "ublock-origin"               "uBlock0@raymondhill.net.xpi"
        amo    "$PROFILE" "bitwarden-password-manager"  "{446900e4-71c2-419f-a6a7-df9c091e268b}.xpi"
        amo    "$PROFILE" "blocktube"                   "{58204f8b-01c2-4bbc-98f8-9a90458fd9ef}.xpi"
        amo    "$PROFILE" "auto-tab-discard"            "{c2c003ee-bd69-42a2-b0e9-6f34222cb046}.xpi"
        amo    "$PROFILE" "chrome-mask"                 "chrome-mask@overengineer.dev.xpi"
        amo    "$PROFILE" "sponsorblock"                "sponsorBlocker@ajay.app.xpi"
        custom "$PROFILE" "alt-tab-tabs.xpi"            "alt-tab-tabs@samuel.local.xpi"
        custom "$PROFILE" "tab-cycle.xpi"               "tab-cycle@samuel.local.xpi"
    done

    # Personal only
    amo "$PERSONAL" "reddit-enhancement-suite"  "jid1-xUfzOsOFlzSOXg@jetpack.xpi"
    amo "$PERSONAL" "tampermonkey"              "firefox@tampermonkey.net.xpi"

    # Utility only
    amo "$UTILITY" "reddit-enhancement-suite"  "jid1-xUfzOsOFlzSOXg@jetpack.xpi"

    echo "Done."

# Fix Homebrew, install packages from ~/.Brewfile, install rtk and bbrew
brew:
    #!/usr/bin/env bash
    set -euo pipefail
    sudo rm -f /etc/.linuxbrew
    sudo systemctl start brew-setup.service || true
    sudo chown -R "$(whoami):wheel" /home/linuxbrew
    sudo chmod -R g+rwX /home/linuxbrew
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    brew bundle --global
    brew install gcc make
    brew install rtk
    rtk init -g --auto-patch || true
    rtk init -g --gemini --auto-patch || true
    BBREW_VERSION=$(curl -fsSL https://api.github.com/repos/Valkyrie00/bold-brew/releases/latest \
        | grep '"tag_name"' | cut -d'"' -f4 | tr -d 'v')
    BBREW_TMP=$(mktemp -d)
    curl -L "https://github.com/Valkyrie00/bold-brew/releases/download/v${BBREW_VERSION}/bbrew_${BBREW_VERSION}_linux_amd64.tar.gz" \
        | tar -xz -C "$BBREW_TMP" \
        && mv "$BBREW_TMP/bbrew" "$(brew --prefix)/bin/bbrew"
    rm -rf "$BBREW_TMP"

# Declaratively install/upgrade Python-based CLI tools from ~/.Pipxfile
pipx:
    #!/usr/bin/env bash
    set -euo pipefail
    PIPX_FILE="{{HOME}}/.Pipxfile"
    [[ -f "$PIPX_FILE" ]] || { echo "~/.Pipxfile not found, skipping."; exit 0; }
    echo "Syncing pipx packages from $PIPX_FILE..."
    while IFS= read -r pkg || [[ -n "$pkg" ]]; do
        [[ "$pkg" =~ ^#.* ]] || [[ -z "$pkg" ]] && continue
        # Strip comments and whitespace
        pkg_name=$(echo "$pkg" | cut -d'#' -f1 | xargs)
        # Extract base package name for 'pipx list' check (removes [extra])
        base_name=$(echo "$pkg_name" | sed 's/\[.*//')
        if pipx list --short | grep -q "^${base_name} "; then
             echo "  Upgrading $pkg_name..."
             pipx upgrade "$pkg_name" &>/dev/null || true
        else
             echo "  Installing $pkg_name..."
             pipx install "$pkg_name"
        fi
    done < "$PIPX_FILE"

