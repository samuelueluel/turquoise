// ============================================================
// GENERAL SETTINGS
// ============================================================

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

hotkey-overlay {
    skip-at-startup
}

animations {
    // off

    slowdown 1 // Slow down all animations by this factor. Values below 1 speed them up instead.

    // Active shader: circle  (switch with: niri-shader <name>)
    window-open {
        duration-ms 750
        curve "ease-out-cubic"
        custom-shader r"
            // Ported from gl-transitions/circleopen.glsl (MIT, gre)

            vec4 open_color(vec3 coords_geo, vec3 size_geo) {
                float p = niri_clamped_progress;
                vec2 uv = coords_geo.xy;
                float seed = niri_random_seed;

                float smoothness = 0.3;
                float SQRT_2 = 1.414213562;

                vec2 center = vec2(0.5 + (seed - 0.5) * 0.15, 0.5 + (seed * 0.7 - 0.35) * 0.15);

                float dist = SQRT_2 * distance(center, uv);
                float m = smoothstep(-smoothness, 0.0, dist - p * (1.0 + smoothness));
                float reveal = 1.0 - m;

                vec3 tc = niri_geo_to_tex * vec3(uv, 1.0);
                vec4 color = texture2D(niri_tex, tc.st);

                return color * reveal;
            }
        "
    }
    window-close {
        duration-ms 750
        curve "ease-out-cubic"
        custom-shader r"
            // Ported from gl-transitions/circleopen.glsl (MIT, gre)

            vec4 close_color(vec3 coords_geo, vec3 size_geo) {
                float p = niri_clamped_progress;
                vec2 uv = coords_geo.xy;
                float seed = niri_random_seed;

                float smoothness = 0.3;
                float SQRT_2 = 1.414213562;

                // Slightly randomized center
                vec2 center = vec2(0.5 + (seed - 0.5) * 0.15, 0.5 + (seed * 0.7 - 0.35) * 0.15);

                float dist = SQRT_2 * distance(center, uv);
                float m = smoothstep(-smoothness, 0.0, dist - (1.0 - p) * (1.0 + smoothness));
                float remain = 1.0 - m;

                vec3 tc = niri_geo_to_tex * vec3(uv, 1.0);
                vec4 color = texture2D(niri_tex, tc.st);

                return color * remain;
            }
        "
    }
}

overview {
    zoom 0.4
}

gestures {
    hot-corners {
        off // This turns off hardcoded top left hot corner
    }
}

// ============================================================
// STARTUP
// ============================================================

// ── Bar + notifications ───────────────────────────────────────────────────
spawn-at-startup "sh" "-c" "swaybg -i $HOME/Pictures/Wallpapers/joonyeop-baek-GK6qXiHm6Iw-unsplash.jpg -m fill"
spawn-at-startup "waybar"
spawn-at-startup "swaync"

// ── OSD (volume/brightness popups) ───────────────────────────────────────
spawn-at-startup "swayosd-server"

// ── Clipboard daemon ──────────────────────────────────────────────────────
spawn-at-startup "sh" "-c" "wl-paste --watch cliphist-store"

// ── Display management ────────────────────────────────────────────────────
spawn-at-startup "kanshi"

// ── Night light ───────────────────────────────────────────────────────────
// spawn-at-startup "wlsunset" "-l" "39.0" "-L" "-77.0"   // US East Coast — adjust lat/lon as needed


// ── Idle management ───────────────────────────────────────────────────────
spawn-at-startup "swayidle" "-w"

// ── Apps ──────────────────────────────────────────────────────────────────
spawn-at-startup "sh" "-c" "sleep 5 && dropbox start -i"
spawn-at-startup "sh" "-c" "sleep 5 && flatpak run com.github.wwmm.easyeffects --gapplication-service"
spawn-at-startup "/usr/bin/niriusd"
spawn-at-startup "udiskie" "--no-tray" // auto-mount USB / external drives
// mpris-proxy removed: airpods-media.service (evdev daemon) handles routing to Quod Libet directly

// ============================================================
// WINDOW RULES
// ============================================================

// --- Global Appearance ---

window-rule {
    geometry-corner-radius 1 // 7; corner roundedness
    clip-to-geometry true
}

// --- Workspace Assignments ---

window-rule {
match {} // Matches everything except exlcuded below
exclude app-id="zen-personal"
exclude app-id="io.github.quodlibet.QuodLibet"
exclude app-id="zen-work"
exclude app-id="kitty"
exclude title="termfilechooser"
exclude title="File Launcher"
exclude title="Folder Launcher"
exclude title="Keybind Search"
exclude title="Clipboard History"
exclude title="Alacritty Float"
exclude title="bluetuith"
exclude title="nmtui"
exclude title="htop"
exclude app-id="org.gnome.SystemMonitor"
exclude app-id="nemo"
exclude app-id="nm-connection-editor"
exclude app-id="blueman-manager"
exclude app-id="com.github.wwmm.easyeffects"
exclude app-id="mpv"
open-on-workspace "utility" // May need to adjust for work-specific apps
}

window-rule {
    match app-id="zen-work"
    open-on-workspace "work"
    default-column-width { proportion 1.0; }
}

window-rule {
    match app-id="zen-personal"
    match app-id="io.github.quodlibet.QuodLibet"
    open-on-workspace "casual"
    default-column-width { proportion 1.0; }
}

// --- Custom Floating Launchers ---

window-rule {
    match title="File Launcher" // Catch the specific window title we set in the bind command
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 800; }
}

window-rule {
    match title="Folder Launcher" // Catch the specific window title we set in the bind command
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 800; }
}

window-rule {
    match title="Yazi Float"
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 800; }
}

window-rule {
    match title="Keybind Search" // Catch the specific window title we set in the bind command
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 800; }
}

window-rule {
    match title="Clipboard History"
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 800; }
}

window-rule {
    match title="Alacritty Float"
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 800; }
}

window-rule {
    match title="nmtui"
    open-floating true
    default-column-width { fixed 800; }
    default-window-height { fixed 550; }
}

window-rule {
    match title="htop"
    open-floating true
    default-column-width { fixed 1200; }
    default-window-height { fixed 700; }
}

window-rule {
    match title="bluetuith"
    open-floating true
    default-column-width { fixed 1000; }
    default-window-height { fixed 600; }
}

// --- Opacity / Dimming ---

// 1. The Global Dimming Rule (Base behavior) --- to make window focus switching a little more obvious
window-rule {
    match is-active=false
    exclude is-floating=true
    opacity 0.75
    draw-border-with-background false
}

// 2. The Picture-in-Picture Exception
window-rule {
    match title="(?i)picture in picture|picture-in-picture"
    opacity 1.0
}

// 3. The Zen "Personal" Exception (Optional)
window-rule {
    match app-id="zen-personal"
    opacity 1.0
}

// 4. The mpv exception
window-rule {
    match app-id="^mpv$"
    opacity 1.0
}

// 5. All floating windows stay fully opaque
window-rule {
    match is-floating=true
    opacity 1.0
}

// ============================================================
// KEYBINDS
// ============================================================

recent-windows { // Disable hard-coded alt+tab binding
    binds {
    }
}

binds {

    // -----------------------------------
    // SYSTEM
    // -----------------------------------

    Mod+0 hotkey-overlay-title="Toggle overview" { toggle-overview; }
    Ctrl+Alt+Delete hotkey-overlay-title="Log out" { quit; }
    Mod+Escape hotkey-overlay-title="Toggle keybind inhibitor for RD/VM" allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    // -----------------------------------
    // SHELL CONTROLS
    // -----------------------------------

    XF86MenuKB hotkey-overlay-title="Toggle minimap" repeat=false { spawn "niri-minimap"; }
    Mod+B hotkey-overlay-title="Toggle Waybar" { spawn-sh "pkill -SIGUSR1 waybar || waybar"; }
    Mod+Space hotkey-overlay-title="App launcher (fuzzel)" repeat=false { spawn "fuzzel"; }
    // Mod+V hotkey-overlay-title="Clipboard history (cliphist)" repeat=false { spawn-sh "cliphist list | fuzzel --dmenu | cliphist decode | wl-copy"; }
    Mod+Y hotkey-overlay-title="Toggle notification center" { spawn "swaync-client" "-t"; }

    // -----------------------------------
    // APPLICATION LAUNCHERS
    // -----------------------------------

    Mod+Grave hotkey-overlay-title="Spawn additional Alacritty"  repeat=false { spawn "alacritty"; }
    Mod+Ctrl+Grave hotkey-overlay-title="Spawn floating Alacritty" repeat=false { spawn "alacritty" "--title" "Alacritty Float"; }
    Mod+E hotkey-overlay-title="Spawn floating Yazi (auto-close on open)" repeat=false { spawn-sh "YAZI_FLOAT=1 kitty --title 'Yazi Float' -e zsh -c 'exec yazi'"; }
    Mod+Ctrl+E hotkey-overlay-title="Spawn Yazi file manager" repeat=false { spawn "kitty" "--title" "yazi" "-e" "zsh" "-c" "exec yazi"; }
    // Mod+Space hotkey-overlay-title="fzf file search (Ctrl+Y to copy)" repeat=false { spawn-sh "alacritty -t 'File Launcher' -e $HOME/.config/niri/open-file.sh"; }
    // Mod+Ctrl+Space hotkey-overlay-title="fzf folder search (Ctrl+Y to copy)" repeat=false { spawn-sh "alacritty -t 'Folder Launcher' -e $HOME/.config/niri/open-folder.sh"; }
    Mod+Slash hotkey-overlay-title="Keybind search" repeat=false { spawn-sh "alacritty -t 'Keybind Search' -e bash -c 'python3 $HOME/.config/niri/niri_parse_keybinds.py | fzf --reverse --border=rounded --info=inline'"; }

    // -----------------------------------
    // WINDOW MANAGEMENT
    // -----------------------------------

    Mod+Ctrl+Q hotkey-overlay-title="Close window"  repeat=false { spawn-sh "~/.config/niri/smart-close.sh"; }
    Mod+P hotkey-overlay-title="Toggle window floating" { toggle-window-floating; } // note this will also make non-floating windows sticky, but buggy
    Mod+Ctrl+P hotkey-overlay-title="Toggle window follow mode" { spawn "/usr/bin/nirius" "toggle-follow-mode"; }

    Mod+O hotkey-overlay-title="Toggle window scratchpad state" { spawn "/usr/bin/nirius" "scratchpad-toggle"; } // Oh not Zero
    Mod+1 hotkey-overlay-title="Show all scratchpad windows" { spawn "/usr/bin/nirius" "scratchpad-show-all"; }
    Mod+2 hotkey-overlay-title="Cycle scratchpad windows" { spawn "/usr/bin/nirius" "scratchpad-show"; }

    Mod+G hotkey-overlay-title="Toggle fullscreen" { fullscreen-window; }
    Mod+Ctrl+G hotkey-overlay-title="Expand column to available width" { expand-column-to-available-width; }
    Mod+F hotkey-overlay-title="Cycle column width" { switch-preset-column-width; }      // cycles over chosen presets
    Mod+Ctrl+F hotkey-overlay-title="Cycle window height" { switch-preset-window-height; } // cycles over chosen presets

    Mod+L hotkey-overlay-title="Toggle column tab mode" { toggle-column-tabbed-display; }

    Mod+Comma hotkey-overlay-title="Consume/expel window left"  { spawn "niri-nav" "consume-or-expel-window-left"; }
    Mod+Period hotkey-overlay-title="Consume/expel window right" { spawn "niri-nav" "consume-or-expel-window-right"; }
    //Mod+Ctrl+Shift+A hotkey-overlay-title="Consume/expel window left"  { spawn "niri-nav" "consume-or-expel-window-left"; }
    //Mod+Ctrl+Shift+D hotkey-overlay-title="Consume/expel window right" { spawn "niri-nav" "consume-or-expel-window-right"; }


    // -----------------------------------
    // FOCUS NAVIGATION
    // -----------------------------------

    Mod+W { spawn "niri-nav" "focus-window-or-workspace-up"; }
    Mod+A { spawn "niri-nav" "focus-column-left"; }
    Mod+S { spawn "niri-nav" "focus-window-or-workspace-down"; }
    Mod+D { spawn "niri-nav" "focus-column-right"; }

    Mod+Up    { focus-window-or-workspace-up; }
    Mod+Left  { focus-column-left; }
    Mod+Down  { focus-window-or-workspace-down; }
    Mod+Right { focus-column-right; }

    //Mod+I hotkey-overlay-title="Toggle focus mode (wallpaper + centering + opacity)" repeat=false { spawn "niri-mode-toggle"; }
    Mod+I hotkey-overlay-title="Toggle tile-scroll mode (50% columns)" repeat=false { spawn "niri-tile-toggle"; }
    Mod+Ctrl+B hotkey-overlay-title="Toggle waybar tray" repeat=false { spawn "waybar-tray-toggle"; }
    Mod+Ctrl+I hotkey-overlay-title="Resize right column to complement of focused" repeat=false { spawn "niri-complement-column"; }

    Mod+Tab hotkey-overlay-title="Focus previous window" { focus-window-previous; }

    // -----------------------------------
    // FOCUS/MOVE COLUMNS AND WINDOWS
    // -----------------------------------

    Mod+Ctrl+W { move-window-up-or-to-workspace-up; }
    Mod+Ctrl+A { move-column-left; }
    Mod+Ctrl+S { move-window-down-or-to-workspace-down; }
    Mod+Ctrl+D { move-column-right; }

    Mod+Ctrl+Up    { move-window-up-or-to-workspace-up; }
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Down  { move-window-down-or-to-workspace-down; }
    Mod+Ctrl+Right { move-column-right; }

    // -----------------------------------
    // RESIZE COLUMNS AND WINDOWS
    // -----------------------------------

    Mod+Minus      { set-column-width "-5%"; }
    Mod+Equal      { set-column-width "+5%"; }

    Mod+Ctrl+Minus { set-window-height "-5%"; }
    Mod+Ctrl+Equal { set-window-height "+5%"; }

    // -----------------------------------
    // FOCUS/MOVE WORKSPACE WITH MOUSE
    // -----------------------------------

    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp   cooldown-ms=150 { focus-workspace-up; }

    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    // -----------------------------------
    // REORDER WORKSPACES
    // -----------------------------------

    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up   { move-workspace-up; }

    // -----------------------------------
    // FOCUS/MOVE MONITOR
    // -----------------------------------

    Mod+Shift+A     { focus-monitor-left; }
    Mod+Shift+S     { focus-monitor-down; }
    Mod+Shift+W     { focus-monitor-up; }
    Mod+Shift+R     { focus-monitor-right; }

    Mod+Shift+Left  { focus-monitor-left; }
    Mod+Shift+Down  { focus-monitor-down; }
    Mod+Shift+Up    { focus-monitor-up; }
    Mod+Shift+Right { focus-monitor-right; }

    //Mod+Shift+Ctrl+A  { move-column-to-monitor-left; }
    //Mod+Shift+Ctrl+S  { move-column-to-monitor-down; }
    //Mod+Shift+Ctrl+W    { move-column-to-monitor-up; }
    //Mod+Shift+Ctrl+D { move-column-to-monitor-right; }

    //Mod+Shift+Ctrl+Left  { move-column-to-monitor-left; }
    //Mod+Shift+Ctrl+Down  { move-column-to-monitor-down; }
    //Mod+Shift+Ctrl+Up    { move-column-to-monitor-up; }
    //Mod+Shift+Ctrl+Right { move-column-to-monitor-right; }

    // -----------------------------------
    // SCROLL BINDS (COLUMN FOCUS AND MOVE)
    // -----------------------------------

    //Mod+WheelScrollRight      { focus-column-right; }
    //Mod+WheelScrollLeft       { focus-column-left; }
    //Mod+Ctrl+WheelScrollRight { move-column-right; }
    //Mod+Ctrl+WheelScrollLeft  { move-column-left; }

    //Mod+Shift+WheelScrollDown      { focus-column-right; }
    //Mod+Shift+WheelScrollUp        { focus-column-left; }
    //Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    //Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    // -----------------------------------
    // CLIPBOARD
    // -----------------------------------

    //Mod+V hotkey-overlay-title="Spawn CopyQ" { spawn "copyq" "toggle"; } just launch from fuzzel

    // -----------------------------------
    // MEDIA CONTROLS
    // -----------------------------------

    XF86AudioPlay  { spawn "playerctl" "--player=quodlibet" "play-pause"; }
    XF86AudioPause { spawn "playerctl" "--player=quodlibet" "play-pause"; }
    XF86AudioNext  { spawn "playerctl" "--player=quodlibet" "next"; }
    XF86AudioPrev  { spawn "playerctl" "--player=quodlibet" "previous"; }

    Mod+Z hotkey-overlay-title="Play/pause Quod Libet"   { spawn "playerctl" "--player=quodlibet" "play-pause"; }
    Mod+Ctrl+Z hotkey-overlay-title="Play/pause Zen" { spawn "playerctl" "--player=firefox" "play-pause"; }

    // -----------------------------------
    // VOLUME AND BRIGHTNESS
    // -----------------------------------

    XF86AudioRaiseVolume allow-when-locked=true { spawn "swayosd-client" "--output-volume" "raise"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "swayosd-client" "--output-volume" "lower"; }
    XF86AudioMute        allow-when-locked=true { spawn "swayosd-client" "--output-volume" "mute-toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "swayosd-client" "--input-volume" "mute-toggle"; }

    XF86MonBrightnessUp   allow-when-locked=true { spawn "swayosd-client" "--brightness" "raise"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "swayosd-client" "--brightness" "lower"; }

    // -----------------------------------
    // SCREENSHOTS
    // -----------------------------------

    Print      { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print  { screenshot-window; }

}

