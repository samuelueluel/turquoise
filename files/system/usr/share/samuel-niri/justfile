# Add user to all required groups and set zsh as default shell
system:
    #!/usr/bin/env bash
    set -euo pipefail
    ME="$(whoami)"

    add_group() {
        local grp="$1"
        getent group "$grp" &>/dev/null || { echo "  skipping $grp (group not found)"; return; }
        groups "$ME" | grep -qw "$grp" && return
        sudo usermod -aG "$grp" "$ME"
        echo "  added to $grp"
    }

    echo "Configuring group memberships..."
    for grp in wheel libvirt kvm lp optical storage video input i2c systemd-journal; do
        add_group "$grp"
    done

    ZSH_PATH="$(command -v zsh)"
    [[ "$SHELL" == "$ZSH_PATH" ]] || sudo usermod -s "$ZSH_PATH" "$ME"

# Replace default zRAM with a 16GB swap file on /var (optional; not in setup)
swap:
    #!/usr/bin/env bash
    set -euo pipefail
    if swapon --show | grep -q '/var/swapfile'; then
        echo "Swap file already active, nothing to do."
        exit 0
    fi
    sudo touch /etc/systemd/zram-generator.conf
    sudo swapoff /dev/zram0 2>/dev/null || true
    sudo fallocate -l 16G /var/swapfile
    sudo chmod 600 /var/swapfile
    sudo mkswap /var/swapfile
    sudo swapon /var/swapfile
    grep -q '/var/swapfile' /etc/fstab || echo '/var/swapfile none swap defaults 0 0' | sudo tee -a /etc/fstab
    swapon --show

# Configure SSH agent socket and load personal key (requires ~/.ssh/id_ed25519; not in setup)
ssh-setup:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ ! -f "$HOME/.ssh/id_ed25519" ]]; then
        echo "No ~/.ssh/id_ed25519 found — this recipe is for Samuel's personal setup only."
        exit 1
    fi
    systemctl --user enable --now ssh-agent.socket
    export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
    SSH_ASKPASS_REQUIRE=never ssh-add ~/.ssh/id_ed25519
    # Append auto-load snippet to ~/.zshrc if not already present
    if ! grep -q 'ssh-add.*id_ed25519' "$HOME/.zshrc" 2>/dev/null; then
        printf '\n# Auto-load SSH key on first terminal (added by sjust ssh-setup)\n[[ -S "$SSH_AUTH_SOCK" ]] && { ssh-add -l &>/dev/null || SSH_ASKPASS_REQUIRE=never ssh-add ~/.ssh/id_ed25519; }\n' >> "$HOME/.zshrc"
        echo "Added ssh-add auto-load to ~/.zshrc."
    fi
    echo "SSH agent socket enabled and key loaded."

# Set up Obsidian CLI wrapper — enables CLI toggle and verifies wrapper is deployed (not in setup)
obsidian-cli:
    #!/usr/bin/env bash
    set -euo pipefail
    OBSIDIAN_JSON="$HOME/.var/app/md.obsidian.Obsidian/config/obsidian/obsidian.json"

    flatpak info md.obsidian.Obsidian &>/dev/null || {
        echo "Obsidian Flatpak not installed. Run 'sjust flatpaks' first."
        exit 1
    }

    pgrep -f "md.obsidian.Obsidian" &>/dev/null && {
        echo "Obsidian is running — close it first so the config change isn't overwritten."
        exit 1
    }

    [[ -f "$OBSIDIAN_JSON" ]] || {
        echo "obsidian.json not found at $OBSIDIAN_JSON — launch Obsidian at least once first."
        exit 1
    }

    python3 -c "import json; fp='$OBSIDIAN_JSON'; data=json.load(open(fp)); data['cli']=True; json.dump(data, open(fp,'w')); print('CLI toggle enabled in obsidian.json')"

    [[ -x "$HOME/.local/bin/obsidian" ]] \
        && echo "Wrapper at ~/.local/bin/obsidian is in place." \
        || echo "Warning: ~/.local/bin/obsidian not found — run 'sjust chezmoi' to deploy dotfiles first."

    echo "Done. Launch Obsidian to activate the socket, then test with: obsidian files"

# Install/upgrade headroom-ai[proxy] via pipx, upgrade all pipx tools, and back up Claude + Gemini config
# Backup requires private SSH key (not in setup); skipped gracefully if unavailable
llm:
    #!/usr/bin/env bash
    set -euo pipefail
    if pipx list --short | grep -q '^headroom-ai '; then
        echo "headroom-ai already installed, skipping install."
    else
        pipx install "headroom-ai[proxy,code,mcp]"
    fi
    pipx upgrade-all
    if git -C "{{HOME}}/system_config_git" ls-remote --exit-code origin &>/dev/null; then
        rsync -av --exclude='sessions/' --exclude='history.jsonl' --exclude='telemetry/' --exclude='cache/' --exclude='image-cache/' --exclude='paste-cache/' --exclude='backups/' {{HOME}}/.claude/ {{HOME}}/system_config_git/claude-backup/claude/
        rsync -av --exclude='history/' --exclude='tmp/samuel/chats/' --exclude='tmp/samuel/tool-outputs/' --exclude='tmp/samuel/logs.json' {{HOME}}/.gemini/ {{HOME}}/system_config_git/claude-backup/gemini/
    else
        echo "Skipping backup — no SSH access to system_config_git."
    fi

# System maintenance: health check, image upgrade, flatpaks, brew, distroboxes, firmware (not in setup)
update:
    #!/usr/bin/env bash
    set -euo pipefail
    echo -e "\033[33mNOTE: uupd handles image, flatpaks, homebrew, and distroboxes automatically daily at 4am.\033[0m"
    echo -e "\033[33mNOTE: Some packages built from source in image recipe are PINNED and won't update without manual intervention; others pull latest release without notification.\033[0m"

    echo -e "\n\033[34m=== System Health Check ===\033[0m"
    echo -e "\033[36m  \$ systemctl --failed\033[0m"
    systemctl --failed || true

    echo -e "\n\033[34m=== Empty Trash? ===\033[0m"
    if command -v trash-empty >/dev/null; then
        trash-empty
    else
        gio trash --empty || true
    fi

    echo -e "\n\033[34m=== Staging Image Update (bootc upgrade) ===\033[0m"
    echo -e "\033[36m  \$ sudo bootc upgrade\033[0m"
    sudo bootc upgrade

    echo -e "\n\033[34m=== Updating Flatpaks ===\033[0m"
    echo -e "\033[36m  \$ flatpak update -y\033[0m"
    flatpak update -y || true

    echo -e "\n\033[34m=== Removing Unused Flatpak Runtimes ===\033[0m"
    echo -e "\033[36m  \$ flatpak uninstall --unused -y\033[0m"
    flatpak uninstall --unused -y || true

    echo -e "\n\033[34m=== Updating Distroboxes ===\033[0m"
    if command -v distrobox >/dev/null; then
        echo -e "\033[36m  \$ distrobox upgrade --all\033[0m"
        distrobox upgrade --all || true
    else
        echo -e "\033[31m  Distrobox not found, skipping.\033[0m"
    fi

    echo -e "\n\033[34m=== Updating Homebrew and Packages ===\033[0m"
    if command -v brew >/dev/null; then
        sudo chown -R "$(whoami):wheel" /home/linuxbrew 2>/dev/null || true
        sudo chmod -R g+rwX /home/linuxbrew 2>/dev/null || true
        echo -e "\033[36m  \$ brew update && brew upgrade && brew cleanup\033[0m"
        brew update && brew upgrade && brew cleanup
    else
        echo -e "\033[31m  Homebrew not found, skipping.\033[0m"
    fi

    echo -e "\n\033[34m=== Checking Firmware Updates ===\033[0m"
    fwupdmgr refresh && fwupdmgr get-updates || true

    echo -e "\n\033[32mUpdate sequence complete!\033[0m"

# Diagnose cursor issues; each check emits one letter so the final CODE string can be memorized and reported back.
check:
    #!/usr/bin/env bash
    # No `set -e` — every check must run even if one fails.

    CODE=""
    # row(letter, name, value, legend) → prints colored row, appends letter to CODE.
    row() {
        local L=$1 NAME=$2 VAL=$3 LEG=$4 COLOR
        case "$L" in
            O|Y|R) COLOR=32 ;;   # green = expected/good
            U|N|F) COLOR=31 ;;   # red   = unexpected/bad
            A|X)   COLOR=33 ;;   # yellow= other / informational
            *)     COLOR=37 ;;
        esac
        printf "  \033[%sm[%s]\033[0m %-26s %-32s \033[90m%s\033[0m\n" "$COLOR" "$L" "$NAME" "$VAL" "$LEG"
        CODE+="$L"
    }

    echo -e "\033[34m=== sjust check (cursor) ===\033[0m"
    echo "user: $(whoami)   host: $(hostname)   date: $(date '+%F %T')"
    echo

    echo -e "\033[34m[A] gsettings\033[0m"
    CURS=$(gsettings get org.gnome.desktop.interface cursor-theme 2>/dev/null | tr -d "'")
    case "$CURS" in
        oreo_spark_orange_cursors) row O "cursor-theme" "$CURS"     "O=oreo A=Adwaita X=other N=missing" ;;
        Adwaita)                   row A "cursor-theme" "$CURS"     "O=oreo A=Adwaita X=other N=missing" ;;
        "")                        row N "cursor-theme" "<missing>" "O=oreo A=Adwaita X=other N=missing" ;;
        *)                         row X "cursor-theme" "$CURS"     "O=oreo A=Adwaita X=other N=missing" ;;
    esac

    echo
    echo -e "\033[34m[B] Waybar runtime env\033[0m"
    WPID=$(pgrep -x waybar | head -1)
    if [[ -z "$WPID" ]]; then
        row N "waybar pid"           "<not running>" "R=running N=not running"
        row N "waybar XCURSOR_THEME" "<no waybar>"   "O=oreo U=unset X=other N=no waybar"
    else
        row R "waybar pid"           "pid $WPID"     "R=running N=not running"
        WENV=$(tr '\0' '\n' < /proc/$WPID/environ 2>/dev/null)
        WX=$(echo "$WENV" | grep '^XCURSOR_THEME=' | cut -d= -f2-)
        case "$WX" in
            oreo_spark_orange_cursors) row O "waybar XCURSOR_THEME" "$WX"     "O=oreo U=unset X=other N=no waybar" ;;
            "")                        row U "waybar XCURSOR_THEME" "<unset>" "O=oreo U=unset X=other N=no waybar" ;;
            *)                         row X "waybar XCURSOR_THEME" "$WX"     "O=oreo U=unset X=other N=no waybar" ;;
        esac
    fi

    echo
    echo -e "\033[34m[B2] XDG desktop portals\033[0m"
    pgrep -x xdg-desktop-portal     >/dev/null 2>&1 && row R "xdg-desktop-portal"     "running" "R=running N=not running" \
                                                     || row N "xdg-desktop-portal"     "not running" "R=running N=not running"
    pgrep -x xdg-desktop-portal-gtk >/dev/null 2>&1 && row R "xdg-desktop-portal-gtk" "running" "R=running N=not running" \
                                                     || row N "xdg-desktop-portal-gtk" "not running" "R=running N=not running"

    echo
    echo -e "\033[34m[C] niri config cursor entries\033[0m"
    NCFG="$HOME/.config/niri/config.kdl"
    if [[ -e "$NCFG" ]]; then
        grep -q 'xcursor-theme "oreo_spark_orange_cursors"' "$NCFG" \
            && row Y "niri xcursor-theme"  "set"     "Y=set N=missing F=no cfg" \
            || row N "niri xcursor-theme"  "missing" "Y=set N=missing F=no cfg"
        grep -q 'XCURSOR_THEME "oreo_spark_orange_cursors"' "$NCFG" \
            && row Y "niri XCURSOR_THEME"  "set"     "Y=set N=missing F=no cfg" \
            || row N "niri XCURSOR_THEME"  "missing" "Y=set N=missing F=no cfg"
    else
        row F "niri xcursor-theme" "<no cfg>" "Y=set N=missing F=no cfg"
        row F "niri XCURSOR_THEME" "<no cfg>" "Y=set N=missing F=no cfg"
    fi

    echo
    echo -e "\033[34m[D] oreo cursor theme content\033[0m"
    OREO=/usr/share/icons/oreo_spark_orange_cursors
    [[ -d "$OREO/cursors" ]] \
        && row Y "oreo theme installed"  "present" "Y=present N=missing" \
        || row N "oreo theme installed"  "missing" "Y=present N=missing"
    [[ -e "$OREO/cursors/pointer" ]] \
        && row Y "oreo: pointer cursor"  "present" "Y=present N=missing" \
        || row N "oreo: pointer cursor"  "missing" "Y=present N=missing"
    [[ -e "$OREO/cursors/default" ]] \
        && row Y "oreo: default cursor"  "present" "Y=present N=missing" \
        || row N "oreo: default cursor"  "missing" "Y=present N=missing"
    OCACHE="$OREO/icon-theme.cache"
    if [[ -e "$OCACHE" ]]; then
        [[ "$OCACHE" -ot "$OREO/index.theme" ]] \
            && row F "oreo icon cache"  "stale"   "Y=fresh F=stale N=missing" \
            || row Y "oreo icon cache"  "fresh"   "Y=fresh F=stale N=missing"
    else
        row N "oreo icon cache"  "<missing>" "Y=fresh F=stale N=missing"
    fi
    if [[ -e "$OREO/index.theme" ]]; then
        row Y "oreo index.theme"    "present" "Y=present N=missing"
        grep -qi '^Type=X11' "$OREO/index.theme" \
            && row Y "oreo index Type=X11"  "set"     "Y=set N=missing" \
            || row N "oreo index Type=X11"  "missing" "Y=set N=missing"
    else
        row N "oreo index.theme"    "missing" "Y=present N=missing"
        row N "oreo index Type=X11" "<no index>" "Y=set N=missing"
    fi

    echo
    echo -e "\033[34m[E] systemd user env\033[0m"
    EDOT="$HOME/.config/environment.d/10-cursor.conf"
    [[ -e "$EDOT" ]] \
        && row Y "env.d/10-cursor.conf"      "present" "Y=present N=missing" \
        || row N "env.d/10-cursor.conf"      "missing" "Y=present N=missing"
    SXC=$(systemctl --user show-environment 2>/dev/null | grep '^XCURSOR_THEME=' | cut -d= -f2-)
    case "$SXC" in
        oreo_spark_orange_cursors) row O "user-mgr XCURSOR_THEME" "$SXC"     "O=oreo U=unset X=other" ;;
        "")                        row U "user-mgr XCURSOR_THEME" "<unset>"  "O=oreo U=unset X=other" ;;
        *)                         row X "user-mgr XCURSOR_THEME" "$SXC"     "O=oreo U=unset X=other" ;;
    esac

    echo
    echo -e "\033[34m[F] default cursor inheritance\033[0m"
    DIDX=/usr/share/icons/default/index.theme
    if [[ -e "$DIDX" ]] && grep -qi '^Inherits.*oreo' "$DIDX"; then
        row Y "default/index.theme" "Inherits=oreo" "Y=oreo N=other/missing"
    else
        row N "default/index.theme" "$([[ -e $DIDX ]] && grep -i '^Inherits' "$DIDX" || echo missing)" "Y=oreo N=other/missing"
    fi

    echo
    echo -e "\033[34m[G] GTK settings.ini cursor\033[0m"
    for VER in 3.0 4.0; do
        INI="$HOME/.config/gtk-$VER/settings.ini"
        if [[ -e "$INI" ]]; then
            CT=$(grep -E '^gtk-cursor-theme-name' "$INI" 2>/dev/null | cut -d= -f2- | tr -d ' ')
            case "$CT" in
                oreo_spark_orange_cursors) row O "gtk-$VER cursor-theme" "$CT"        "O=oreo A=Adwaita X=other N=missing" ;;
                Adwaita)                   row A "gtk-$VER cursor-theme" "$CT"        "O=oreo A=Adwaita X=other N=missing" ;;
                "")                        row N "gtk-$VER cursor-theme" "<not set>"  "O=oreo A=Adwaita X=other N=missing" ;;
                *)                         row X "gtk-$VER cursor-theme" "$CT"        "O=oreo A=Adwaita X=other N=missing" ;;
            esac
        else
            row N "gtk-$VER cursor-theme" "<no ini>" "O=oreo A=Adwaita X=other N=missing"
        fi
    done

    echo
    echo -e "\033[34m=== CODE (read this aloud) ===\033[0m"
    # Group as A(1) B(4) C(2) D(6) E(2) F(1) G(2) = 18 chars total.
    A=${CODE:0:1}; B=${CODE:1:4}; C=${CODE:5:2}; D=${CODE:7:6}
    E=${CODE:13:2}; F=${CODE:15:1}; G=${CODE:16:2}
    echo -e "  \033[1;36m$A $B $C $D $E $F $G\033[0m"
    echo
    echo "  positions:  A1  B1 B2 B3 B4  C1 C2  D1 D2 D3 D4 D5 D6  E1 E2  F1  G1 G2"
    echo "  A: gsettings cursor-theme"
    echo "  B: waybar (pid, XCURSOR_THEME) + portals (xdg-desktop-portal, xdg-desktop-portal-gtk)"
    echo "  C: niri config (xcursor-theme, XCURSOR_THEME env)"
    echo "  D: oreo theme (installed, pointer, default, cache, index.theme, Type=X11)"
    echo "  E: systemd env (env.d file, user-mgr XCURSOR_THEME)"
    echo "  F: default cursor inheritance"
    echo "  G: GTK settings.ini cursor (gtk-3.0, gtk-4.0)"
